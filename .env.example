# Gmail SMTP (use an App Password — https://myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your_16_char_app_password_no_spaces

# Shown to customers in the From field (real SMTP_USER stays hidden)
SMTP_FROM_NAME=Superjet Visa
SMTP_FROM_EMAIL=no-reply@superjetglobal.com
SMTP_REPLY_TO=inquiry@superjetgroup.com

# Contact form messages are delivered here
CONTACT_TO=procurement@superjetgroup.com

API_PORT=3001

# Stripe (test mode) — https://dashboard.stripe.com/test/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
# Dev only: simulate successful checkout when no Stripe key (default on in dev)
# VITE_STRIPE_MOCK_CHECKOUT=true

# Passport OCR (omkar.cloud) — used when enabled in Admin → Settings → OCR
PASSPORT_OCR_API_KEY=
